TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=

# Threads (uses same Meta auth — needs threads_basic + threads_content_publish permissions)
THREADS_USER_ID=
